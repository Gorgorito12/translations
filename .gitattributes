# Auto detect text files and perform LF normalization
* text=auto

# Translation pack archives + images are BINARY — never normalize line endings,
# or the .zip checksums break and the launcher can't extract them.
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

# translation.json must keep LF (its bytes feed the MD5/content-hash checks).
*.json text eol=lf
